# Shared / Backend
SITE_URL=http://localhost:5173
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
COMMISSION_BPS=1000
PAYSTACK_PAYOUT_COUNTRY=ghana
# Arkesel OTP requires your main SMS API key, not a multiple API key.
ARKESEL_API_KEY=
# Sender ID must be 11 characters or fewer.
ARKESEL_SENDER_ID=CRIB
ARKESEL_OTP_EXPIRY_MINUTES=10
ARKESEL_OTP_LENGTH=6
ARKESEL_OTP_MEDIUM=sms
ARKESEL_OTP_TYPE=numeric
ARKESEL_REGISTER_OTP_MESSAGE=Your CRIB verification code is %otp_code%. It expires in %expiry% minutes.
ARKESEL_RESET_OTP_MESSAGE=Your CRIB password reset code is %otp_code%. It expires in %expiry% minutes.

# Supabase
